<?xml version="1.0" encoding="utf-8"?>
<animation-list xmlns:android="http://schemas.android.com/apk/res/android"
    android:oneshot="false">

    <item android:duration="4000">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#DAF1DE"
                android:endColor="#235347"
                android:angle="45" />
        </shape>
    </item>

    <item android:duration="4000">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#8EB69B"
                android:endColor="#051F20"
                android:angle="135" />
        </shape>
    </item>

    <item android:duration="4000">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#6B11FF"
                android:endColor="#667eea"
                android:angle="225" />
        </shape>
    </item>
</animation-list>